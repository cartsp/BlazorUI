@page "/matrix-rain"
@using BlazorEffects.MatrixRain
@using AppHost.Shared

<EffectDemoLayout EffectName="Matrix Rain"
                  EffectIcon="🌧️"
                  Presets="_presets"
                  CurrentPreset="_currentPresetKey"
                  OnPresetSelected="ApplyPreset"
                  Parameters="_parameterGroups"
                  OnParameterChanged="OnParameterChanged"
                  GenerateCode="GenerateMarkup">
    <EffectContent>
        <BlazorEffects.MatrixRain.MatrixRain
            Height="100vh"
            TargetFps="30"
            Characters="@_state.Characters"
            FontSize="@_state.FontSize"
            Color="@_state.Color"
            FadeColor="@_state.FadeColor"
            Speed="@_state.Speed"
            Density="@_state.Density"
            Opacity="@_state.Opacity" />
    </EffectContent>
</EffectDemoLayout>

@code {
    // --- Demo presets (from approved spec) ---

    private static readonly List<PresetOption> _presets =
    [
        new("classic", "Classic"),
        new("cyberpunk", "Cyberpunk"),
        new("terminal", "Terminal"),
        new("ghost", "Ghost"),
        new("sunset", "Sunset")
    ];

    private static readonly Dictionary<string, MatrixRainDemoState> PresetStates = new()
    {
        ["classic"] = new()
        {
            Characters = MatrixRainPresets.Classic,
            Color = "#00ff41", FadeColor = "#003b00",
            Speed = 1.0, Density = 1.0, FontSize = 16, Opacity = 0.8
        },
        ["cyberpunk"] = new()
        {
            Characters = MatrixRainPresets.Katakana,
            Color = "#ff00ff", FadeColor = "#1a0033",
            Speed = 1.2, Density = 0.8, FontSize = 16, Opacity = 0.85
        },
        ["terminal"] = new()
        {
            Characters = MatrixRainPresets.Binary,
            Color = "#00ff88", FadeColor = "#001a0d",
            Speed = 0.8, Density = 0.9, FontSize = 14, Opacity = 0.75
        },
        ["ghost"] = new()
        {
            Characters = MatrixRainPresets.Classic,
            Color = "#ffffff", FadeColor = "#0a0a0a",
            Speed = 0.6, Density = 0.7, FontSize = 16, Opacity = 0.6
        },
        ["sunset"] = new()
        {
            Characters = MatrixRainPresets.Hex,
            Color = "#ff6b35", FadeColor = "#1a0800",
            Speed = 1.0, Density = 1.0, FontSize = 16, Opacity = 0.8
        }
    };

    // --- State ---

    private string _currentPresetKey = "classic";
    private MatrixRainDemoState _state = PresetStates["classic"];

    // --- Parameter groups (reactive from state) ---

    private List<ParameterGroup> _parameterGroups => BuildParameterGroups();

    // --- Preset handler ---

    private void ApplyPreset(string key)
    {
        if (PresetStates.TryGetValue(key, out var preset))
        {
            _state = preset with { }; // create copy
            _currentPresetKey = key;
        }
    }

    // --- Parameter change handler ---

    private void OnParameterChanged((string Name, string Value) change)
    {
        _currentPresetKey = ""; // clear preset highlight on manual change
        _state = change.Name switch
        {
            "color"     => _state with { Color = change.Value },
            "fadeColor" => _state with { FadeColor = change.Value },
            "speed"     => _state with { Speed = double.Parse(change.Value) },
            "density"   => _state with { Density = double.Parse(change.Value) },
            "fontSize"  => _state with { FontSize = double.Parse(change.Value) },
            "opacity"   => _state with { Opacity = double.Parse(change.Value) },
            _ => _state
        };
    }

    // --- Code snippet generator ---

    private string GenerateMarkup() => $"""
        <MatrixRain
            Color="@_state.Color"
            FadeColor="@_state.FadeColor"
            Speed="@_state.Speed.ToString("F1")"
            Density="@_state.Density.ToString("F1")"
            FontSize="@_state.FontSize.ToString("F0")"
            Opacity="@_state.Opacity.ToString("F1")"
            TargetFps="30" />
        """;

    // --- Build parameter groups from current state ---

    private List<ParameterGroup> BuildParameterGroups() =>
    [
        new("Appearance",
        [
            new ColorParameter("color", "Color", _state.Color),
            new ColorParameter("fadeColor", "Fade Color", _state.FadeColor),
            new RangeParameter("opacity", "Opacity", _state.Opacity, 0.1, 1.0, 0.1, "F1"),
        ]),
        new("Behavior",
        [
            new RangeParameter("speed", "Speed", _state.Speed, 0.1, 3.0, 0.1, "F1"),
            new RangeParameter("density", "Density", _state.Density, 0.1, 1.0, 0.1, "F1"),
            new RangeParameter("fontSize", "Font Size", _state.FontSize, 8, 32, 1, "F0"),
        ])
    ];

    // --- State record ---

    private record MatrixRainDemoState
    {
        public string Characters { get; init; } = MatrixRainPresets.Classic;
        public double FontSize { get; init; } = 16;
        public string Color { get; init; } = "#00ff41";
        public string FadeColor { get; init; } = "#003b00";
        public double Speed { get; init; } = 1.0;
        public double Density { get; init; } = 1.0;
        public double Opacity { get; init; } = 0.8;
    }
}
