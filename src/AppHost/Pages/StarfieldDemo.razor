@page "/starfield"
@using BlazorEffects.Starfield

<div class="relative">
    <Starfield
        Height="100vh"
        TargetFps="@_targetFps"
        StarCount="@_starCount"
        StarColor="@_starColor"
        StarSize="@_starSize"
        Speed="@_speed"
        TrailLength="@_trailLength"
        Depth="@_depth"
        BackgroundColor="@_backgroundColor"
        Opacity="@_opacity">
        <div class="relative z-10 flex flex-col items-center justify-center h-full text-white">
            <h1 class="text-6xl font-bold mb-4 drop-shadow-lg">Starfield</h1>
            <p class="text-xl mb-8 drop-shadow-md opacity-80">Warp-speed star background effect</p>

            <div class="bg-black/60 backdrop-blur-sm rounded-xl p-6 max-w-md w-full mx-4">
                <h2 class="text-lg font-semibold mb-4 text-blue-400">Controls</h2>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Preset</label>
                        <select @bind="_selectedPreset" @bind:event="oninput" class="w-full bg-gray-800 text-white rounded px-3 py-2 border border-gray-600">
                            <option value="Default">Hyperspace</option>
                            <option value="WarpDrive">Warp Drive</option>
                            <option value="GoldenDrift">Golden Drift</option>
                            <option value="Sparse">Sparse</option>
                            <option value="Blizzard">Blizzard</option>
                            <option value="RetroTerminal">Retro Terminal</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Star Count: @_starCount</label>
                        <input type="range" min="50" max="3000" step="50" @bind="_starCount" class="w-full" />
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Star Size: @_starSize</label>
                        <input type="range" min="0.5" max="5" step="0.5" @bind="_starSize" class="w-full" />
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Speed: @_speed.ToString("F1")</label>
                        <input type="range" min="0.2" max="8" step="0.2" @bind="_speed" class="w-full" />
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Trail Length: @_trailLength.ToString("F2")</label>
                        <input type="range" min="0" max="1" step="0.05" @bind="_trailLength" class="w-full" />
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Depth: @_depth</label>
                        <input type="range" min="200" max="3000" step="100" @bind="_depth" class="w-full" />
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Opacity: @_opacity.ToString("F2")</label>
                        <input type="range" min="0.1" max="1" step="0.05" @bind="_opacity" class="w-full" />
                    </div>

                    <div>
                        <label class="block text-sm mb-1 text-gray-300">Target FPS: @_targetFps</label>
                        <input type="range" min="15" max="120" step="5" @bind="_targetFps" class="w-full" />
                    </div>
                </div>
            </div>

            <a href="/" class="mt-6 text-blue-400 hover:text-blue-300 underline">&larr; Back to Home</a>
        </div>
    </Starfield>
</div>

@code {
    private string _selectedPreset = "Default";
    private int _starCount = 800;
    private string _starColor = "#ffffff";
    private double _starSize = 2.0;
    private double _speed = 2.0;
    private double _trailLength = 0.6;
    private double _depth = 1000;
    private string _backgroundColor = "#000000";
    private double _opacity = 1.0;
    private int _targetFps = 60;

    private StarfieldConfig _currentPreset => _selectedPreset switch
    {
        "Default" => StarfieldPresets.Default,
        "WarpDrive" => StarfieldPresets.WarpDrive,
        "GoldenDrift" => StarfieldPresets.GoldenDrift,
        "Sparse" => StarfieldPresets.Sparse,
        "Blizzard" => StarfieldPresets.Blizzard,
        "RetroTerminal" => StarfieldPresets.RetroTerminal,
        _ => StarfieldPresets.Default
    };

    protected override void OnParametersSet()
    {
        var preset = _currentPreset;
        _starCount = preset.StarCount;
        _starColor = preset.StarColor;
        _starSize = preset.StarSize;
        _speed = preset.Speed;
        _trailLength = preset.TrailLength;
        _depth = preset.Depth;
        _backgroundColor = preset.BackgroundColor;
        _opacity = preset.Opacity;
        StateHasChanged();
    }
}
