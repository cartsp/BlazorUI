@page "/"
@using BlazorEffects.MatrixRain
@using BlazorEffects.GradientWaves

<div class="relative min-h-screen overflow-hidden bg-[#0a0a0a]">
    @* Hero background effect — Gradient Waves *@
    <div class="fixed inset-0 z-0 opacity-40">
        <GradientWaves Colors="_heroColors" Speed="0.3" />
    </div>

    @* Content layer *@
    <div class="relative z-10">
        @* Navigation *@
        <nav class="flex items-center justify-between px-6 py-4 md:px-12">
            <div class="flex items-center gap-2">
                <span class="text-2xl">✨</span>
                <span class="text-white font-bold text-lg tracking-tight">BlazorEffects</span>
            </div>
            <div class="flex items-center gap-6">
                <a href="playground" class="text-white/60 hover:text-white transition-colors text-sm">Playground</a>
                <a href="https://github.com/cartsp/BlazorUI" target="_blank" class="text-white/60 hover:text-white transition-colors text-sm">
                    GitHub ↗
                </a>
            </div>
        </nav>

        @* Hero Section *@
        <section class="flex flex-col items-center justify-center text-center px-6 pt-24 pb-16 md:pt-32 md:pb-24">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/70 text-xs mb-8">
                <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                Open source · MIT licensed
            </div>

            <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight leading-tight mb-6">
                Blazor Effects<br />
                <span class="bg-gradient-to-r from-purple-400 via-pink-400 to-cyan-400 bg-clip-text text-transparent">
                    that stop scrolling
                </span>
            </h1>

            <p class="text-lg md:text-xl text-white/50 max-w-2xl mb-10 leading-relaxed">
                Canvas-powered animations, particle systems, and generative art —
                packaged as drop-in Razor Class Libraries for Blazor.
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-4">
                <a href="playground" class="group relative px-8 py-3.5 bg-white text-black font-semibold rounded-xl hover:bg-white/90 transition-all shadow-lg shadow-white/20">
                    Open Playground
                    <span class="ml-1 group-hover:translate-x-0.5 transition-transform inline-block">→</span>
                </a>
                <a href="https://github.com/cartsp/BlazorUI" target="_blank"
                   class="px-8 py-3.5 bg-white/10 text-white font-medium rounded-xl border border-white/10 hover:bg-white/15 transition-all backdrop-blur-sm">
                    View Source
                </a>
            </div>

            @* Tech badges *@
            <div class="flex items-center gap-3 mt-10 text-white/30 text-xs">
                <span class="px-2.5 py-1 rounded-full bg-white/5 border border-white/10">.NET 8</span>
                <span class="px-2.5 py-1 rounded-full bg-white/5 border border-white/10">.NET 9</span>
                <span class="px-2.5 py-1 rounded-full bg-white/5 border border-white/10">.NET 10</span>
                <span class="px-2.5 py-1 rounded-full bg-white/5 border border-white/10">Canvas API</span>
                <span class="px-2.5 py-1 rounded-full bg-white/5 border border-white/10">60fps</span>
            </div>
        </section>

        @* Effect Gallery *@
        <section class="px-6 md:px-12 pb-20">
            <div class="max-w-6xl mx-auto">
                <h2 class="text-sm font-medium uppercase tracking-widest text-white/30 mb-8 text-center">Six effects. Infinite combinations.</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    @foreach (var effect in _effects)
                    {
                        <a href="playground" class="group relative rounded-2xl overflow-hidden border border-white/10 bg-white/5 hover:border-white/20 transition-all duration-300">
                            <div class="aspect-video relative overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-br @effect.GradientClass opacity-80"></div>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-4xl group-hover:scale-110 transition-transform duration-300">@effect.Icon</span>
                                </div>
                            </div>
                            <div class="p-4">
                                <h3 class="text-white font-semibold text-sm">@effect.Name</h3>
                                <p class="text-white/40 text-xs mt-1">@effect.Description</p>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>

        @* Code Example Section *@
        <section class="px-6 md:px-12 pb-20">
            <div class="max-w-3xl mx-auto">
                <h2 class="text-sm font-medium uppercase tracking-widest text-white/30 mb-6 text-center">Drop in. That's it.</h2>

                <div class="rounded-2xl border border-white/10 bg-[#0d1117] overflow-hidden">
                    <div class="flex items-center gap-2 px-4 py-3 border-b border-white/10">
                        <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
                        <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
                        <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
                        <span class="text-white/30 text-xs ml-2 font-mono">Index.razor</span>
                    </div>
                    <pre class="p-5 text-sm font-mono leading-relaxed overflow-x-auto text-white/70">@_codeExample</pre>
                </div>
            </div>
        </section>

        @* Footer *@
        <footer class="px-6 md:px-12 py-8 border-t border-white/5">
            <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2 text-white/30 text-sm">
                    <span>✨</span>
                    <span>BlazorEffects — built with 💜 by <a href="https://github.com/cartsp" target="_blank" class="text-white/50 hover:text-white/70 transition-colors">cartsp</a></span>
                </div>
                <div class="flex items-center gap-4 text-white/30 text-sm">
                    <a href="https://github.com/cartsp/BlazorUI" target="_blank" class="hover:text-white/50 transition-colors">GitHub</a>
                    <span>·</span>
                    <span>MIT License</span>
                </div>
            </div>
        </footer>
    </div>
</div>

@code {
    private readonly string[] _heroColors = ["#7c3aed", "#db2777", "#0891b2", "#059669"];

    private readonly string _codeExample = """
        <MatrixRain Color="#00ff41" Speed="1.2">
            <h1>Welcome to the Matrix</h1>
        </MatrixRain>

        <ParticleConstellation
            Config="ParticleConstellationPresets.DeepSpace" />

        <AuroraBorealis
            Colors="@(["#00ff87", "#7b2ff7", "#00b4d8"])" />
        """;

    private readonly record struct EffectCard(string Icon, string Name, string Description, string GradientClass);

    private readonly List<EffectCard> _effects =
    [
        new("🌧️", "Matrix Rain", "Cascading character rain à la The Matrix", "from-green-900/50 to-emerald-950/50"),
        new("🌌", "Particle Constellation", "Connected particle network with glowing lines", "from-indigo-900/50 to-violet-950/50"),
        new("🌈", "Aurora Borealis", "Flowing curtains of multi-color light", "from-teal-900/50 to-cyan-950/50"),
        new("🫧", "Morphing Blobs", "Organic gradient blobs with smooth blending", "from-pink-900/50 to-rose-950/50"),
        new("🌊", "Noise Field", "Animated simplex noise with flowing gradients", "from-purple-900/50 to-fuchsia-950/50"),
        new("🧿", "Gradient Waves", "Smoothly morphing mesh gradient — Stripe-style", "from-amber-900/50 to-orange-950/50"),
    ];
}
