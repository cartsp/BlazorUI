@inherits BlazorEffects.Core.Animation.EffectComponentBase

<div class="matrix-rain-container" style="position:relative;height:@Height;overflow:hidden;">
    <canvas @ref="CanvasElement" aria-hidden="true" role="presentation"
            style="position:absolute;top:0;left:0;width:100%;height:100%;opacity:@Opacity.ToString("F2");">
    </canvas>
    @if (ChildContent is not null)
    {
        <div class="matrix-rain-overlay @CssClass" style="position:relative;z-index:1;">
            @ChildContent
        </div>
    }
</div>

@code {
    /// <summary>
    /// Character pool for the rain streams.
    /// </summary>
    [Parameter] public string Characters { get; set; } = MatrixRainPresets.Classic;

    /// <summary>
    /// Font size in px (also determines column width).
    /// </summary>
    [Parameter] public double FontSize { get; set; } = 16;

    /// <summary>
    /// Canvas font family.
    /// </summary>
    [Parameter] public string FontFamily { get; set; } = "monospace";

    /// <summary>
    /// Lead character color.
    /// </summary>
    [Parameter] public string Color { get; set; } = "#00ff41";

    /// <summary>
    /// Background fade color for the trailing effect.
    /// </summary>
    [Parameter] public string FadeColor { get; set; } = "#003b00";

    /// <summary>
    /// Fall speed multiplier.
    /// </summary>
    [Parameter] public double Speed { get; set; } = 1.0;

    /// <summary>
    /// Active column fraction (0.0-1.0).
    /// </summary>
    [Parameter] public double Density { get; set; } = 1.0;

    /// <summary>
    /// Overall effect opacity.
    /// </summary>
    [Parameter] public double Opacity { get; set; } = 0.8;

    protected override string ModulePath => "./_content/BlazorEffects.MatrixRain/matrix-rain.js";

    protected override object BuildConfig() => new MatrixRainConfig
    {
        Characters = Characters,
        FontSize = FontSize,
        FontFamily = FontFamily,
        Color = Color,
        FadeColor = FadeColor,
        Speed = Speed,
        Density = Density,
        Opacity = Opacity,
        ReducedMotionBehavior = ReducedMotionBehavior.ToString(),
        TargetFps = TargetFps
    };

    protected override string ComputeConfigHash()
    {
        return $"{Characters}|{FontSize}|{FontFamily}|{Color}|{FadeColor}|{Speed}|{Density}|{Opacity}|{ReducedMotionBehavior}|{TargetFps}";
    }
}
