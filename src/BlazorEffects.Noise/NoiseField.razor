@inherits BlazorEffects.Core.Animation.EffectComponentBase

<div class="noise-field-container" style="position:relative;height:@Height;overflow:hidden;background:#000;">
    <canvas @ref="CanvasElement"
            style="position:absolute;top:0;left:0;width:100%;height:100%;opacity:@Opacity.ToString("F2");">
    </canvas>
    @if (ChildContent is not null)
    {
        <div class="noise-field-overlay @CssClass" style="position:relative;z-index:1;">
            @ChildContent
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gradient color palette for mapping noise values.
    /// </summary>
    [Parameter] public string[] ColorStops { get; set; } = NoiseFieldPresets.Default;

    /// <summary>
    /// Zoom level of noise. Lower = smoother, larger features.
    /// </summary>
    [Parameter] public double NoiseScale { get; set; } = 0.003;

    /// <summary>
    /// Evolution speed of the noise animation.
    /// </summary>
    [Parameter] public double Speed { get; set; } = 0.005;

    /// <summary>
    /// Number of noise octaves (fractal Brownian motion).
    /// </summary>
    [Parameter] public int Octaves { get; set; } = 4;

    /// <summary>
    /// Amplitude multiplier per octave.
    /// </summary>
    [Parameter] public double Persistence { get; set; } = 0.5;

    /// <summary>
    /// Frequency multiplier per octave.
    /// </summary>
    [Parameter] public double Lacunarity { get; set; } = 2.0;

    /// <summary>
    /// Color brightness multiplier.
    /// </summary>
    [Parameter] public double Brightness { get; set; } = 1.0;

    /// <summary>
    /// Overall effect opacity.
    /// </summary>
    [Parameter] public double Opacity { get; set; } = 0.85;

    protected override string ModulePath => "./_content/BlazorEffects.Noise/noise-field.js";

    protected override object BuildConfig() => new NoiseFieldConfig
    {
        ColorStops = ColorStops,
        NoiseScale = NoiseScale,
        Speed = Speed,
        Octaves = Octaves,
        Persistence = Persistence,
        Lacunarity = Lacunarity,
        Brightness = Brightness,
        Opacity = Opacity,
        TargetFps = TargetFps
    };

    protected override string ComputeConfigHash()
    {
        var colorHash = string.Join(",", ColorStops);
        return $"{colorHash}|{NoiseScale}|{Speed}|{Octaves}|{Persistence}|{Lacunarity}|{Brightness}|{Opacity}|{TargetFps}";
    }
}
