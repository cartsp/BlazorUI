<div class="py-3 px-4 border-b border-white/5">
    <div class="flex justify-between items-center mb-1.5">
        <label class="text-sm font-medium text-white/80"
               for="@Id">@Label</label>
        <span class="text-sm font-mono text-accent-400 tabular-nums">@Value</span>
    </div>
    @if (Max - Min <= 20 && Step == 1)
    {
        <div class="flex flex-wrap gap-1.5">
            @for (var i = (int)Min; i <= (int)Max; i += (int)Step)
            {
                var val = i;
                var isActive = val == Value;
                <button @onclick="() => HandleSelect(val)"
                        class="min-w-[32px] px-2 py-1 text-xs font-medium rounded-md transition-colors duration-150 @GetButtonClass(isActive)">
                    @val
                </button>
            }
        </div>
    }
    else
    {
        <input type="range"
               id="@Id"
               class="playground-slider"
               min="@Min"
               max="@Max"
               step="@Step"
               value="@Value"
               @oninput="HandleInput"
               aria-label="@Label"
               aria-valuemin="@Min"
               aria-valuemax="@Max"
               aria-valuenow="@Value"
               style="--fill-pct: @GetFillPercentage()" />
    }
    @if (Description is not null)
    {
        <p class="text-xs text-white/30 mt-0.5">@Description</p>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Max { get; set; } = 10;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public string? Description { get; set; }
    [Parameter] public EventCallback<int> OnChange { get; set; }

    private string GetFillPercentage()
    {
        var range = Max - Min;
        if (range <= 0) return "0%";
        var pct = ((Value - Min) / range) * 100;
        return $"{Math.Clamp(pct, 0, 100):F1}%";
    }

    private string GetButtonClass(bool isActive) => isActive
        ? "bg-accent-500 text-white"
        : "bg-white/5 text-white/60 hover:bg-white/10";

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            await OnChange.InvokeAsync(val);
        }
    }

    private async Task HandleSelect(int val)
    {
        await OnChange.InvokeAsync(val);
    }
}
