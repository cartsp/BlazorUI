<div class="py-3 px-4 border-b border-white/5">
    <div class="flex justify-between items-center mb-1.5">
        <label class="text-sm font-medium text-white/80"
               for="@Id">@Label</label>
        <span class="text-sm font-mono text-accent-400 tabular-nums">@FormatValue(Value)</span>
    </div>
    <input type="range"
           id="@Id"
           class="playground-slider"
           min="@Min"
           max="@Max"
           step="@Step"
           value="@Value"
           @oninput="HandleInput"
           aria-label="@Label"
           aria-valuemin="@Min"
           aria-valuemax="@Max"
           aria-valuenow="@Value"
           style="--fill-pct: @GetFillPercentage()" />
    @if (Description is not null)
    {
        <p class="text-xs text-white/30 mt-0.5">@Description</p>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public double Value { get; set; }
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Max { get; set; } = 1;
    [Parameter] public double Step { get; set; } = 0.01;
    [Parameter] public string? Description { get; set; }
    [Parameter] public EventCallback<double> OnChange { get; set; }

    private string GetFillPercentage()
    {
        var range = Max - Min;
        if (range <= 0) return "0%";
        var pct = ((Value - Min) / range) * 100;
        return $"{Math.Clamp(pct, 0, 100):F1}%";
    }

    private string FormatValue(double val)
    {
        if (Step >= 1) return ((int)val).ToString();
        if (Step >= 0.1) return val.ToString("F1");
        if (Step >= 0.01) return val.ToString("F2");
        if (Step >= 0.001) return val.ToString("F3");
        return val.ToString("F4");
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            await OnChange.InvokeAsync(val);
        }
    }
}
