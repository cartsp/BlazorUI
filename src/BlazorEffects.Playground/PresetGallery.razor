<div class="px-4 py-3">
    <h3 class="text-xs font-medium uppercase tracking-wider text-white/40 mb-3">Presets</h3>
    <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-none">
        @foreach (var preset in Presets)
        {
            var isSelected = preset.Name == ActivePreset;
            <button @onclick="() => OnSelect.InvokeAsync(preset.Name)"
                    aria-label="@($"{preset.Name} preset")"
                    aria-pressed="@isSelected.ToString().ToLowerInvariant()"
                    class="flex-shrink-0 flex flex-col items-center gap-1 group transition-all duration-150">
                <div class="w-[60px] h-[40px] rounded-lg transition-all duration-150 group-hover:scale-105 group-hover:ring-1 group-hover:ring-white/30 @GetRingClasses(isSelected)"
                     style="background: @preset.PreviewGradient"
                     title="@preset.Description">
                </div>
                <span class="text-[10px] font-medium @GetTextClasses(isSelected)">@preset.Name</span>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<EffectPresetView> Presets { get; set; } = [];
    [Parameter] public string? ActivePreset { get; set; }
    [Parameter] public EventCallback<string> OnSelect { get; set; }

    private string GetRingClasses(bool isSelected) => isSelected
        ? "ring-2 ring-accent-500 ring-offset-2 ring-offset-[#0f172a]"
        : "ring-1 ring-white/10";

    private string GetTextClasses(bool isSelected) => isSelected
        ? "text-accent-400"
        : "text-white/40 group-hover:text-white/60";
}
